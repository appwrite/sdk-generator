{% autoescape false %}
{%- set requireFilesPkg = false -%}
{%- set requireOsPkg = false -%}
{%- set requireModelsPkg = false -%}
{%- for method in service.methods -%}
    {%- if (method | getValidResponseModels)|length > 1 -%}
        {%- set requireModelsPkg = true -%}
    {%- endif -%}
    {%- for parameter in method.parameters.all -%}
        {%- if "file.InputFile" in (parameter | typeName) -%}
            {%- set requireFilesPkg = true -%}
            {%- set requireOsPkg = true -%}
        {%- endif -%}
    {%- endfor -%}
{%- endfor -%}
{% macro render_json_value(definitions, property, spec, indent = '') -%}
{%- import _self as helper -%}
{%- set childIndent = indent ~ '    ' -%}
{%- if property.sub_schema and definitions[property.sub_schema] -%}
    {%- set requiredProps = definitions[property.sub_schema].properties | filter(p => p.required) -%}
    {%- if property.type == 'array' -%}
[
{{ childIndent }}{
{% for prop in requiredProps %}
{{ childIndent }}    "{{ prop.name | replace({'"': '\\"', '\\': '\\\\'}) }}": {{ helper.render_json_value(definitions, prop, spec, childIndent ~ '    ') | trim | raw }}{% if not loop.last %},{% endif %}{{ "\n" -}}
{% endfor %}
{{ childIndent }}}
{{ indent }}]
    {%- else -%}
{
{% for prop in requiredProps %}
{{ indent }}    "{{ prop.name | replace({'"': '\\"', '\\': '\\\\'}) }}": {{ helper.render_json_value(definitions, prop, spec, indent ~ '    ') | trim | raw }}{% if not loop.last %},{% endif %}{{ "\n" -}}
{% endfor %}
{{ indent }}}
    {%- endif -%}
{%- else -%}
    {%- if property.type == 'object' -%}
{}
    {%- elseif property.type == 'array' -%}
[]
    {%- elseif property.type == 'string' -%}
"{{ (property.example | default('string')) | replace({'"': '\\"', '\\': '\\\\'}) }}"
    {%- elseif property.type == 'boolean' -%}
true
    {%- elseif property.type == 'integer' -%}
{{ property.example | default(1) }}
    {%- elseif property.type == 'number' -%}
{{ property.example | default(1.0) }}
    {%- else -%}
{{ (property.example is empty) ? "null" : property.example }}
    {%- endif -%}
{%- endif -%}
{%- endmacro %}
package {{ service.name | caseLower }}

import (
	"net/http"
	"net/http/httptest"
	"testing"
{% if requireOsPkg %}	"os"
{% endif %}

	"{{ sdk | goPackagePath }}/client"
{% if requireModelsPkg %}	"{{ sdk | goPackagePath }}/models"
{% endif %}
{% if requireFilesPkg %}	"{{ sdk | goPackagePath }}/file"
{%- endif %}
)

func Test{{ service.name | caseUcfirst }}(t *testing.T) {
{% if requireOsPkg %}
	tmpFile, err := os.CreateTemp("", "test")
	if err != nil {
		t.Fatal(err)
	}
	defer os.Remove(tmpFile.Name())
	_, _ = tmpFile.WriteString("test content")
	_ = tmpFile.Close()
{% endif %}
	newTestClient := func(ts *httptest.Server) client.Client {
		c := client.New()
		c.Endpoint = ts.URL
		c.Client = ts.Client()
		return c
	}

{% for method in service.methods %}
{% if not loop.first %}

{% endif %}
	t.Run("Test {{ method.name | caseUcfirst }}", func(t *testing.T) {
{% if method.type == 'webAuth' %}
{% if (method | returnType(spec, spec.title | caseLower)) == 'bool' %}
		mockResponse := `true`
{% else %}
		mockResponse := `"https://example.com"`
{% endif %}
{% elseif method.type == 'location' %}
		mockData := []byte("image_data")
{% else %}
{% set responseModels = method | getValidResponseModels %}
{% set responseDiscriminator = method.responseDiscriminator ?? {} %}
{% set responseModelName = '' %}
{% if responseModels|length > 1 %}
{% set responseModelName = responseModels|last %}
{% elseif method.responseModel and method.responseModel != 'any' %}
{% set responseModelName = method.responseModel %}
{% endif %}
{% if responseModelName %}
{% for definition in spec.definitions %}
{% if definition.name == responseModelName %}
{% set discriminatorConditions = responseDiscriminator[responseModelName] ?? {} %}
		mockResponse := `
{
{% for property in definition.properties | filter((param) => param.required) %}
    "{{ property.name | replace({'"': '\\"', '\\': '\\\\'}) }}": {% if discriminatorConditions[property.name] is defined %}"{{ discriminatorConditions[property.name] | replace({'"': '\\"', '\\': '\\\\'}) }}"{% else %}{{ _self.render_json_value(spec.definitions, property, spec, '    ') | trim | raw }}{% endif %}{% if not loop.last %},{% endif %}{{ "\n" -}}
{% endfor %}
}
`
{% endif %}
{% endfor %}
{% else %}
		mockResponse := `
{
    "message": "success"
}
`
{% endif %}
{% endif %}

		ts := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
{% set methodUsesFile = false %}
{% for parameter in method.parameters.all %}
{% if "file.InputFile" in (parameter | typeName) %}
{% set methodUsesFile = true %}
{% endif %}
{% endfor %}
{% if methodUsesFile and method.method | upper != 'GET' %}
			if r.Method == "GET" && "{{ method.method | upper }}" != "GET" {
				// Handle file upload resume check
				w.Header().Set("Content-Type", "application/json")
				w.WriteHeader(http.StatusOK)
				_, _ = w.Write([]byte(`{"chunksUploaded": 0}`))
				return
			}
{% endif %}
			if r.Method != "{{ method.method | upper }}" {
				t.Errorf("Expected method {{ method.method | upper }}, got %s", r.Method)
			}

			w.Header().Set("Content-Type", {% if method.type == 'location' %}"image/png"{% else %}"application/json"{% endif %})
			w.WriteHeader(http.StatusOK)
{% if method.type == 'location' %}
			_, _ = w.Write(mockData)
{% else %}
			_, _ = w.Write([]byte(mockResponse))
{% endif %}
		}))
		defer ts.Close()

		srv := New(newTestClient(ts))

{% set params = '' %}
{% for parameter in method.parameters.all | filter((param) => param.required) %}
{% set val = '' %}
{% set type = (parameter | typeName) %}
{% if "file.InputFile" in type %}
{% set val = 'file.NewInputFile(tmpFile.Name(), "test.txt")' %}
{% elseif parameter.type == 'object' %}
{% set val = 'map[string]interface{}{}' %}
{% elseif parameter.type == 'array' %}
{% if parameter.items.type == 'string' %}
{% set val = '[]string{}' %}
{% else %}
{% set val = type ~ '{}' %}
{% endif %}
{% elseif parameter.type == 'boolean' %}
{% set val = 'true' %}
{% elseif parameter.type == 'string' %}
{% set val = '"' ~ (parameter.example | replace({'"': '\\"', '\\': '\\\\'})) ~ '"' %}
{% elseif parameter.type == 'integer' %}
{% set val = '1' %}
{% elseif parameter.type == 'number' %}
{% set val = '1.0' %}
{% else %}
{% set val = parameter.example %}
{% endif %}
{% set params = params ~ val %}
{% if not loop.last %}{% set params = params ~ ', ' %}{% endif %}
{% endfor %}
{% if responseModels|length > 1 %}
		response, err := srv.{{ method.name | caseUcfirst }}({{ params }})
{% else %}
		_, err := srv.{{ method.name | caseUcfirst }}({{ params }})
{% endif %}
		if err != nil {
			t.Errorf("Method {{ method.name | caseUcfirst }} failed: %v", err)
		}
{% if responseModels|length > 1 %}
		if _, ok := response.(*models.{{ responseModelName | caseUcfirst }}); !ok {
			t.Errorf("Expected response type *models.{{ responseModelName | caseUcfirst }}, got %T", response)
		}
{% endif %}
	})
{% endfor %}
}
{% endautoescape %}

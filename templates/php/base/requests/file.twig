{% for parameter in method.parameters.all %}
{% if parameter.type == 'file' %}
{% set responseModels = method | getResponseModels(spec) %}
{% set filteredResponseModelNames = method.responseModels | filter((modelName) => modelName is not empty and modelName != 'any') %}
{% set hasResponseDiscriminator = method.responseDiscriminator is defined and method.responseDiscriminator is not empty %}
{% set responseDiscriminator = method.responseDiscriminator ?? {} %}
{% set unionDispatch = method | getUnionDispatch(spec) %}
        $size = 0;
        $mimeType = null;
        $postedName = null;
        if(empty(${{ parameter.name | caseCamel }}->getPath() ?? null)) {
            $size = strlen(${{ parameter.name | caseCamel }}->getData());
            $mimeType = ${{ parameter.name | caseCamel }}->getMimeType();
            $postedName = ${{ parameter.name | caseCamel }}->getFilename();
            if ($size <= Client::CHUNK_SIZE) {
                $apiParams['{{ parameter.name | caseCamel }}'] = new \CURLFile('data://' . $mimeType . ';base64,' . base64_encode(${{ parameter.name | caseCamel }}->getData()), $mimeType, $postedName);
                $response = $this->client->call(Client::METHOD_POST, $apiPath, [
    {% for param in method.parameters.header %}
                    '{{ param.name }}' => ${{ param.name | caseCamel }},
    {% endfor %}
    {% for key, header in method.headers %}
                    '{{ key }}' => '{{ header }}',
    {% endfor %}
                    ], $apiParams);
{% if responseModels | length > 0 %}
{% if responseModels | length > 1 and hasResponseDiscriminator %}
                if (!is_array($response)) {
                    throw new \UnexpectedValueException('Expected array response when hydrating a response model.');
                }
{% for modelName, conditions in responseDiscriminator %}
                if ({% for field, expectedValue in conditions %}($response['{{ field }}'] ?? null) == '{{ expectedValue }}'{% if not loop.last %} && {% endif %}{% endfor %}) {
                    return \Appwrite\Models\{{ modelName | caseUcfirst }}::from($response);
                }
{% endfor %}
                throw new \UnexpectedValueException('Unable to match response to any expected response model.');
{% else %}
                return $this->parseResponse(
                    $response,
                    [{% for responseModel in responseModels %}{{ responseModel }}::class{{ loop.last ? '' : ', ' }}{% endfor %}]
{% if responseModels | length > 1 %},
                    [
{% for modelName in filteredResponseModelNames %}
                    {{ responseModels[loop.index0] }}::class => [
                        'conditions' => [{% for field, expectedValue in unionDispatch[modelName].conditions %}'{{ field }}' => '{{ expectedValue }}'{{ loop.last ? '' : ', ' }}{% endfor %}],
                        'required' => [{% for field in unionDispatch[modelName].required %}'{{ field }}'{{ loop.last ? '' : ', ' }}{% endfor %}],
                        'all' => [{% for field in unionDispatch[modelName].all %}'{{ field }}'{{ loop.last ? '' : ', ' }}{% endfor %}],
                    ]{{ loop.last ? '' : ',' }}
{% endfor %}
                    ]
{% endif %}
                );
{% endif %}
{% else %}
                return $response;
{% endif %}
            }
        } else {
            $size = filesize(${{ parameter.name | caseCamel }}->getPath());
            $mimeType = ${{ parameter.name | caseCamel }}->getMimeType() ?? mime_content_type(${{ parameter.name | caseCamel }}->getPath());
            $postedName = ${{ parameter.name | caseCamel }}->getFilename() ?? basename(${{ parameter.name | caseCamel }}->getPath());
            //send single file if size is less than or equal to 5MB
            if ($size <= Client::CHUNK_SIZE) {
                $apiParams['{{ parameter.name }}'] = new \CURLFile(${{ parameter.name | caseCamel }}->getPath(), $mimeType, $postedName);
                $response = $this->client->call(Client::METHOD_{{ method.method | caseUpper }}, $apiPath, [
    {% for param in method.parameters.header %}
                    '{{ param.name }}' => ${{ param.name | caseCamel }},
    {% endfor %}
    {% for key, header in method.headers %}
                    '{{ key }}' => '{{ header }}',
    {% endfor %}
                    ], $apiParams);
{% if responseModels | length > 0 %}

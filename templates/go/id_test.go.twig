{% autoescape false %}
package id

import (
	"testing"
)

func TestUnique(t *testing.T) {
	id := Unique()
	if len(id) != 20 {
		t.Errorf("Expected length 20, got %d", len(id))
	}
}

func TestCustom(t *testing.T) {
	id := Custom("custom_id")
	if id != "custom_id" {
		t.Errorf("Expected custom_id, got %s", id)
	}
}
{% endautoescape %}

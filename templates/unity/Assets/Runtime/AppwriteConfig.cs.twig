        {{ service.name | caseUcfirst }} = 1 << {{ loop.index0 }},
{% endfor %}

        [Tooltip("Selects all available services.")]
        All = {% for service in spec.services %}{{ service.name | caseUcfirst }}{% if not loop.last %} | {% endif %}{% endfor %}


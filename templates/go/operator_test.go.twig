package operator_test

import (
	"encoding/json"
	"testing"

	appwriteoperator "{{ sdk | goPackagePath }}/operator"
)

func TestIncrement(t *testing.T) {
	q := appwriteoperator.Increment(1)
	var data map[string]interface{}
	if err := json.Unmarshal([]byte(q), &data); err != nil {
		t.Fatal(err)
	}

	if data["method"] != "increment" {
		t.Errorf("Expected increment, got %s", data["method"])
	}
	values := data["values"].([]interface{})
	if values[0].(float64) != 1 {
		t.Errorf("Expected [1], got %v", values[0])
	}
}

func TestDecrement(t *testing.T) {
	q := appwriteoperator.Decrement(1, 0)
	var data map[string]interface{}
	if err := json.Unmarshal([]byte(q), &data); err != nil {
		t.Fatal(err)
	}

	if data["method"] != "decrement" {
		t.Errorf("Expected decrement, got %s", data["method"])
	}
	values := data["values"].([]interface{})
	if values[0].(float64) != 1 {
		t.Errorf("Expected decrement amount to be 1, got %v", values[0])
	}
	if values[1].(float64) != 0 {
		t.Errorf("Expected default value to be 0, got %v", values[1])
	}
}


extends Node

func _ready():
    # If the Appwrite Autoload is configured, you can directly use it
    Appwrite.set_endpoint("https://cloud.appwrite.io/v1")
    Appwrite.set_project("YOUR_PROJECT_ID")
    Appwrite.set_key("YOUR_API_KEY")
    
{% if method.type != 'webAuth' %}
    var result = await Appwrite.{{ service.name | caseCamel }}.{{ method.name | caseSnake }}(
{% else %}
    var result = Appwrite.{{ service.name | caseCamel }}.{{ method.name | caseSnake }}(
{% endif %}
{% for parameter in method.parameters.all %}
        {{ parameter | paramExample }}{% if not loop.last %},{% endif %}{% if not parameter.required %} # optional{% endif %}

{% endfor %}
    )

    if result is Appwrite.Exception:
        print("Error: ", result.message)
    else:
        print(result)
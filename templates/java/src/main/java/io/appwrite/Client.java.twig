    public Client(String endPoint, boolean selfSigned) {
        this.endPoint = endPoint;
        headers.put("content-type", "application/json");
        headers.put("user-agent", "{{ spec.title | caseUcfirst }}{{ language.name | caseUcfirst }}SDK/{{ sdk.version }} " + System.getProperty("http.agent", ""));
        headers.put("x-sdk-name", "{{ sdk.name }}");
        headers.put("x-sdk-platform", "{{ sdk.platform }}");
        headers.put("x-sdk-language", "{{ language.name | caseLower }}");
        headers.put("x-sdk-version", "{{ sdk.version }}");
        {%~ for key, header in spec.global.defaultHeaders %}
        headers.put("{{ key | caseLower }}", "{{ header }}");
        {%~ endfor %}
        setSelfSigned(selfSigned);
    }


{
  "name": "{{ language.params.npmPackage | caseDash }}",
  "homepage": "{{ spec.contactURL }}",
  "description": "{{ sdk.shortDescription }}",
  "version": "{{ sdk.version }}",
  "license": "{{ sdk.license }}",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsup",
    "test": "jest"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./file": {
      "import": {
        "types": "./dist/inputFile.d.mts",
        "default": "./dist/inputFile.mjs"
      },
      "require": {
        "types": "./dist/inputFile.d.ts",
        "default": "./dist/inputFile.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "{{ sdk.gitURL }}"
  },
  "devDependencies": {
    "@types/json-bigint": "1.0.4",
    "@types/node": "26.1.1",
    "tsup": "^8.5.1",
    "esbuild-plugin-file-path-extensions": "^2.0.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "jest": "^30.4.2"
  },
  "dependencies": {
    "json-bigint": "1.0.0",
    "undici": "^6.27.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "js-yaml": "^4.2.0"
  }
}

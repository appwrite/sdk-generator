internal struct UnionResponseModelDispatch {
    let conditions: [String: String]
    let required: [String]
    let all: [String]
    let hydrate: ([String: Any]) -> Any
}

open class Service {

    internal var client: Client

    public init(_ client: Client)
    {
        self.client = client
    }

    internal func parseResponse(_ response: Any, dispatch: [UnionResponseModelDispatch]) -> Any {
        guard let responseMap = response as? [String: Any], !dispatch.isEmpty else {
            return response
        }

        let responseKeys = Set(responseMap.keys)
        var bestMatch: UnionResponseModelDispatch?
        var bestScore = -1

        for candidate in dispatch {
            let score: Int

            if !candidate.conditions.isEmpty {
                let matches = candidate.conditions.allSatisfy { key, expected in
                    guard let actual = responseMap[key] else {
                        return false
                    }

                    return String(describing: actual) == expected
                }

                if !matches {
                    continue
                }

                score = candidate.conditions.count
            } else {
                let hasRequiredFields = candidate.required.allSatisfy { responseKeys.contains($0) }
                if !hasRequiredFields {
                    continue
                }

                score = candidate.all.reduce(into: 0) { result, field in
                    if responseKeys.contains(field) {
                        result += 1
                    }
                }
            }

            if score > bestScore {
                bestScore = score
                bestMatch = candidate
            }
        }

        return bestMatch?.hydrate(responseMap) ?? {
            fatalError("Unable to match response to any expected response model")
        }()
    }
}

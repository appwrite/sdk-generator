static func array_prepend(values: Array) -> String:
    return {{spec.title | caseUcfirst}}Operator.new("arrayPrepend", values).to_string()

static func array_insert(index: int, value: Variant) -> String:
    return {{spec.title | caseUcfirst}}Operator.new("arrayInsert", [index, value]).to_string()

